# ── Android Test Station Pro — Environment Configuration ────────────
# Copy this file to .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────────
PORT=8000

# ── ADB / scrcpy paths (optional, defaults to PATH) ─────────────────
# ADB_PATH=/usr/local/bin/adb
# SCRCPY_PATH=/usr/local/bin/scrcpy

# ── Dropbox Integration ──────────────────────────────────────────────
# 1. Go to https://www.dropbox.com/developers/apps
# 2. Click "Create app" → choose "Scoped access" → "Full Dropbox"
# 3. Name your app, then go to Permissions tab
# 4. Enable: files.content.write, files.content.read, files.metadata.read
# 5. Go to Settings tab → OAuth 2 → Generate access token
# 6. Paste the token below:

DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# Folder in Dropbox where recordings will be stored (created automatically)
DROPBOX_FOLDER=/AndroidTestRecordings
